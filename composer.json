{
  "name": "dschuppelius/php-common-toolkit",
  "description": "Project description.",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Daniel Joerg Schuppelius",
      "email": "info@schuppelius.org"
    }
  ],
  "autoload": {
    "psr-4": {
      "CommonToolkit\\": "src/"
    }
  },
  "prefer-stable": true,
  "require": {
    "php": ">=8.1 <8.6",
    "ext-bcmath": "*",
    "ext-dom": "*",
    "ext-intl": "*",
    "ext-zip": "*",
    "dschuppelius/php-config-toolkit": "^0.4.3",
    "maxmind-db/reader": "^1.11"
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "phpstan/phpstan": "^2.1",
    "laravel/pint": "^1.27"
  },
  "scripts": {
    "test": "vendor/bin/phpunit",
    "format": "vendor/bin/pint --test",
    "format:fix": "vendor/bin/pint",
    "lint": "vendor/bin/phpstan analyse --memory-limit=1G",
    "qa": [
      "@format",
      "@lint",
      "@test"
    ]
  }
}
